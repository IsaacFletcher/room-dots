# Mako Modern Glass Template
max-history=5
sort=-time

# Visuals
layer=overlay
anchor=top-right
font=CaskaydiaMono Nerd Font 10
width=350
margin=20
padding=15
border-size=2
border-radius=12
icons=1
max-icon-size=48
default-timeout=5000

# Colors (Filled by Pywal)
background-color=#101019CC
text-color=#eac8bd
border-color=#EEA47D
progress-color=over #EEA47D

[urgency=high]
border-color=#C0717F
default-timeout=0
